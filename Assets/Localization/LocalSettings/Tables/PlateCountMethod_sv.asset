  m_TableData:
  - m_Id: 277162754048
    m_Localized: "Uppdraget utf\xF6rt:"
    m_Metadata:
      m_Items: []
  - m_Id: 837869895680
    m_Localized: "Tv\xE4tta h\xE4nderna!"
    m_Metadata:
      m_Items: []
  - m_Id: 1105739120640
    m_Localized: "Pipettera de n\xF6dv\xE4ndiga m\xE4ngderna fosfatbuffert i provr\xF6ren."
    m_Metadata:
      m_Items: []
  - m_Id: 1432215355392
    m_Localized: Rent blev det!
    m_Metadata:
      m_Items: []
  - m_Id: 7292832956887040
    m_Localized: "R\xF6ren \xE4r fyllda!"
    m_Metadata:
      m_Items: []
  - m_Id: 29158718955794432
    m_Localized: "Ta de sterila verktygen till laminarsk\xE5pet."
    m_Metadata:
      m_Items: []
  - m_Id: 29806597881479168
    m_Localized: "Allt n\xF6dv\xE4ndigt \xE4r i sk\xE5pet!"
    m_Metadata:
      m_Items: []
  - m_Id: 33067695887093760
    m_Localized: "Spreja dina h\xE4nder med sprejflaskan."
    m_Metadata:
      m_Items: []
  - m_Id: 33077598357819392
    m_Localized: "Just s\xE5 som det s\xE4gs, laga verktygen i sk\xE5pet."
    m_Metadata:
      m_Items: []
  - m_Id: 33078251536781312
    m_Localized: "Pipetera 4,5 ml fosfatbuffert i tre tomma provr\xF6r och i den
      fj\xE4rde 1ml."
    m_Metadata:
      m_Items: []
  - m_Id: 34124328254087168
    m_Localized: "F\xF6rbered sennasuspension."
    m_Metadata:
      m_Items: []
  - m_Id: 34124711118544896
    m_Localized: "Tills\xE4tt 5 ml fosfatbuffert i r\xF6ret och blanda med pipetten
      genom att dra v\xE4tskan upp och ner."
    m_Metadata:
      m_Items: []
  - m_Id: 34125544694521856
    m_Localized: "Utf\xF6r seriell sp\xE4dning."
    m_Metadata:
      m_Items: []
  - m_Id: 34126482754805760
    m_Localized: "Ta 0,5 ml av suspensionen, \xF6verf\xF6r den till ett 1:10 provr\xF6r
      och blanda. Forts\xE4tt med 0,5 ml av suspensionen fr\xE5n f\xF6reg\xE5ende
      r\xF6r."
    m_Metadata:
      m_Items: []
  - m_Id: 34126911748218880
    m_Localized: "Skriv ner utsp\xE4dningsf\xF6rh\xE5llandena i provr\xF6ren."
    m_Metadata:
      m_Items: []
  - m_Id: 34127290590339072
    m_Localized: "Skriv sp\xE4dningsf\xF6rh\xE5llandena i provr\xF6ren: 1:10, 1:100,
      1:1000 och kontroll."
    m_Metadata:
      m_Items: []
  - m_Id: 34127532878503936
    m_Localized: "Provr\xF6r korrekt m\xE4rkta!"
    m_Metadata:
      m_Items: []
  - m_Id: 34128086983811072
    m_Localized: Bra gjort med seriell dilution :D
    m_Metadata:
      m_Items: []
  - m_Id: 34128399572705280
    m_Localized: "Du har f\xF6rberett upph\xE4ngningen!"
    m_Metadata:
      m_Items: []
  references:
