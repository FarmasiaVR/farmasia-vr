  m_SharedData: {fileID: 11400000, guid: 924fc04d4b6d5f1de989144c8bdfa227, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 277162754048
    m_Localized: "Teht\xE4v\xE4 suoritettu: "
    m_Metadata:
      m_Items: []
  - m_Id: 837869895680
    m_Localized: "Pese k\xE4tesi!"
    m_Metadata:
      m_Items: []
  - m_Id: 1105739120640
    m_Localized: "Pipetoi tarvittavat m\xE4\xE4r\xE4t fosfaattipuskuria koeputkiin."
    m_Metadata:
      m_Items: []
  - m_Id: 1432215355392
    m_Localized: Puhdasta tuli!
    m_Metadata:
      m_Items: []
  - m_Id: 7292832956887040
    m_Localized: "Putket t\xE4ytetty!"
    m_Metadata:
      m_Items: []
  - m_Id: 29158718955794432
    m_Localized: "Vie steriloidut ty\xF6v\xE4lineet laminaarikaappiin"
    m_Metadata:
      m_Items: []
  - m_Id: 29806597881479168
    m_Localized: Kaikki tarvittava on kaapissa!
    m_Metadata:
      m_Items: []
  - m_Id: 33067695887093760
    m_Localized: "Suihkauta k\xE4si\xE4si suihkepullolla."
    m_Metadata:
      m_Items: []
  - m_Id: 33077598357819392
    m_Localized: "Just kuten siin\xE4 sanotaan, laita ty\xF6kalut kaappiin."
    m_Metadata:
      m_Items: []
  - m_Id: 33078251536781312
    m_Localized: "Pipetoi kolmeen tyhj\xE4\xE4n koeputkeen 4,5 ml fosfaattipuskuria
      ja nelj\xE4nteen 1ml."
    m_Metadata:
      m_Items: []
  - m_Id: 34124328254087168
    m_Localized: Valmista sennasuspensio.
    m_Metadata:
      m_Items: []
  - m_Id: 34124711118544896
    m_Localized: "Mittaa 5ml fosfaattipuskuria sennajauheputkeen ja sekoita pipettorilla
      vet\xE4m\xE4ll\xE4 nestett\xE4 yl\xF6s-alas."
    m_Metadata:
      m_Items: []
  - m_Id: 34125544694521856
    m_Localized: Tee sarjalaimennos.
    m_Metadata:
      m_Items: []
  - m_Id: 34126482754805760
    m_Localized: "Mittaa rohdossuspensiosta 0,5ml suspensiota, siirr\xE4 sen 1:10-merkattuun
      koeputkeen ja sekoita. Jatka eteenp\xE4in k\xE4ytt\xE4m\xE4ll\xE4 0,5ml suspensiota
      edellisest\xE4 putkista."
    m_Metadata:
      m_Items: []
  - m_Id: 34126911748218880
    m_Localized: Kirjoita laimennossuhteet koeputkiin.
    m_Metadata:
      m_Items: []
  - m_Id: 34127290590339072
    m_Localized: 'Kirjoita koeputkiin niiden laimennossuhteet: 1:10, 1:100, 1:1000
      ja kontrolli.'
    m_Metadata:
      m_Items: []
  - m_Id: 34127532878503936
    m_Localized: Koeputket merkattu oikein!
    m_Metadata:
      m_Items: []
  - m_Id: 34128086983811072
    m_Localized: Hyvin tehty sarjalaimennos :D
    m_Metadata:
      m_Items: []
  - m_Id: 34128399572705280
    m_Localized: Valmistelit suspension!
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
